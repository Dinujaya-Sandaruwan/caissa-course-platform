{
  "info": {
    "name": "Caissa Chess Academy API",
    "description": "API collection for the Caissa Chess Academy Course Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"whatsappNumber\": \"94771234567\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/send-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "send-otp"]
            },
            "description": "Sends a 6-digit OTP to the provided WhatsApp number. Rate limited to 3 attempts per 10 minutes."
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"whatsappNumber\": \"94771234567\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-otp"]
            },
            "description": "Verifies the OTP and returns session cookie. Returns isNewUser: true if user needs to complete registration, or isNewUser: false with role if user exists."
          },
          "response": []
        },
        {
          "name": "Complete Registration (Student)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kasun Perera\",\n  \"email\": \"kasun@example.com\",\n  \"role\": \"student\",\n  \"dateOfBirth\": \"2005-03-15\",\n  \"gender\": \"male\",\n  \"skillLevel\": \"beginner\",\n  \"city\": \"Colombo\",\n  \"preferredLanguage\": \"en\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/complete-registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "complete-registration"]
            },
            "description": "Completes registration for a new student after OTP verification. Creates User + StudentProfile."
          },
          "response": []
        },
        {
          "name": "Complete Registration (Coach)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"GM Arjun Sharma\",\n  \"email\": \"arjun@example.com\",\n  \"role\": \"coach\",\n  \"dateOfBirth\": \"1990-08-20\",\n  \"fideId\": \"123456789\",\n  \"fideRating\": 2450,\n  \"address\": \"123 Chess Lane, Colombo\",\n  \"coachAchievements\": [\"National Coach Award 2023\"],\n  \"playerAchievements\": [\"Sri Lanka Open Champion 2022\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/complete-registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "complete-registration"]
            },
            "description": "Completes registration for a new coach after OTP verification. Creates User + CoachProfile with pending verification."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Clears the session cookie and logs the user out."
          },
          "response": []
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/session",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "session"]
            },
            "description": "Returns the current authenticated user's userId, role, and whatsappNumber. Returns 401 if not logged in."
          },
          "response": []
        }
      ]
    }
  ]
}
